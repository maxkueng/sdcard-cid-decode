{
  "name": "sdcard-cid-decode",
  "version": "2.0.0",
  "description": "SD card CID Decoder",
  "keywords": [
    "sd",
    "sdcard",
    "sd card",
    "securedigital",
    "secure digital",
    "securedigitalcard",
    "secure digital card",
    "cid",
    "card identification",
    "decode",
    "decoder",
    "typescript"
  ],
  "author": "Max Kueng (https://maxkueng.com/contact)",
  "license": "MIT",
  "homepage": "https://github.com/maxkueng/sdcard-cid-decode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxkueng/sdcard-cid-decode.git"
  },
  "bugs": {
    "url": "https://github.com/maxkueng/sdcard-cid-decode/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs/promises').then(f => f.rm('dist', { recursive: true, force: true }))\"",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run clean && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
